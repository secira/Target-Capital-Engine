# Copy this to .env and fill in the values.
# Never commit .env to git.

# ---- Database ----
# PostgreSQL DSN for the scoped tc_exec user (read-only on users/broker_account/trading_signal;
# insert/update on trade/broker_order only)
DATABASE_URL=postgresql://tc_exec:<password>@<host>:5432/<dbname>

# ---- HMAC ----
# Shared with Target Capital — must match EXACTLY on both sides.
# Generate with: openssl rand -hex 32
EXECUTION_HMAC_SECRET=changeme-generate-with-openssl-rand-hex-32

# Secret rotation: set this to the incoming key during a rotation window.
# The engine will accept signatures valid against EITHER key.
# Once all callers use the new key: delete the line above, rename this to EXECUTION_HMAC_SECRET.
EXECUTION_HMAC_SECRET_NEXT=

# ---- Broker encryption ----
# 32-byte Fernet key, base64-encoded. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BROKER_ENCRYPTION_KEY=

# ---- Admin ----
# Protects PUT /v1/halt
ADMIN_TOKEN=changeme-generate-with-openssl-rand-hex-16

# ---- App ----
PORT=5000
LOG_LEVEL=INFO

# ---- Halt state ----
# Path to SQLite file that stores halt state across restarts
HALT_DB_PATH=halt_state.db
